{
  "python.defaultInterpreterPath": "/home/yeti/.virtualenvs/cercetador/bin/python",
  "python.analysis.extraPaths": ["${workspaceFolder}"],
  "python.terminal.activateEnvironment": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": false,
  "python.testing.cwd": "${workspaceFolder}",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/*.egg-info": true,
    "**/.eggs": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/htmlcov": true,
    "**/.coverage": true
  },
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [120]
  }
}
